# Port the service listens on
PORT=8080

# Base URL for OpenMRS (internal Docker network name)
OPENMRS_URL=http://openmrs:8080

# Per-request timeout for OpenMRS calls, in milliseconds.
# OPENMRS_TIMEOUT_MS=10000

# Absolute path to the templates directory.
# In production: mounted from standard-config Docker volume (do not change).
# In local dev: point to your standard-config checkout, e.g.:
#   TEMPLATES_DIR=/path/to/standard-config/print-templates
TEMPLATES_DIR=/etc/bahmni_config/print-templates

# Set to "debug" to log presence of session headers per request.
# LOG_LEVEL=debug
